# Frontend env vars. Copy to frontend/.env.local.
# Frontend is UI only — it does NOT connect to Postgres, Redis, Google, Resend,
# or any external service. All of those live in the FastAPI backend.

NODE_ENV=development

# Public URL of this app (used for server-side links only)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# FastAPI base URL — every fetch from the browser goes here.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Server-side API URL — used by Next server components to fetch /auth/me etc.
# In most setups this is the same as NEXT_PUBLIC_API_URL.
API_URL=http://localhost:8000

# Optional analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
